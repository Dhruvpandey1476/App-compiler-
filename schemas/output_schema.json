{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AppCompilerOutput",
  "description": "Contract for the full compiled application schema",
  "type": "object",
  "required": ["meta","intent","system_design","database","api","ui","auth","validation"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["generated_at","pipeline_version","input_prompt","total_duration_ms"],
      "properties": {
        "generated_at": {"type":"string","format":"date-time"},
        "pipeline_version": {"type":"string"},
        "input_prompt": {"type":"string"},
        "total_duration_ms": {"type":"number"}
      }
    },
    "intent": {
      "type": "object",
      "required": ["app_name","app_type","core_features","user_roles"],
      "properties": {
        "app_name": {"type":"string"},
        "app_type": {"type":"string","enum":["crm","ecommerce","saas","cms","social","marketplace","analytics","other"]},
        "description": {"type":"string"},
        "core_features": {"type":"array","items":{"type":"string"}},
        "user_roles": {"type":"array","items":{"type":"object","required":["name","capabilities"],"properties":{"name":{"type":"string"},"capabilities":{"type":"array","items":{"type":"string"}}}}},
        "business_rules": {"type":"array","items":{"type":"string"}},
        "assumptions": {"type":"array","items":{"type":"string"}},
        "clarifications_needed": {"type":"array","items":{"type":"string"}}
      }
    },
    "database": {
      "type": "object",
      "required": ["tables"],
      "properties": {
        "tables": {"type":"array","minItems":1,"items":{"type":"object","required":["name","columns"],"properties":{"name":{"type":"string"},"columns":{"type":"array","items":{"type":"object","required":["name","type"]}}}}},
        "enums": {"type":"array"}
      }
    },
    "api": {
      "type": "object",
      "required": ["endpoints"],
      "properties": {
        "base_url": {"type":"string"},
        "endpoints": {"type":"array","minItems":1,"items":{"type":"object","required":["path","method","auth_required"]}}
      }
    },
    "ui": {
      "type": "object",
      "required": ["pages"],
      "properties": {
        "pages": {"type":"array","minItems":1},
        "navigation": {"type":"object"},
        "global_components": {"type":"array","items":{"type":"string"}}
      }
    },
    "auth": {
      "type": "object",
      "required": ["strategy","roles","permissions"],
      "properties": {
        "strategy": {"type":"string"},
        "roles": {"type":"array"},
        "permissions": {"type":"array"}
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "client_issues": {"type":"array"},
        "llm_audit": {"type":"object"}
      }
    }
  }
}
